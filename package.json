{
  "name": "codeflag",
  "displayName": "CodeFlag",
  "description": "Allows you to add flags to your code, so that its easier to find later on...",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeflag.flag",
    "onCommand:codeflag.unflag"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeflag.welcomeMessage",
        "title": "welcome message"
      },
      {
        "command": "codeflag.flag",
        "title": "Flag code"
      },
      {
        "command": "codeflag.unflag",
        "title": "Unflag code"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
