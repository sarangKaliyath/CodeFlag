{
  "name": "codeflag",
  "displayName": "CodeFlag",
  "publisher": "sarang-kaliyath",
  "description": "Allows you to add flags to your code, so that its easier to find later on...",
  "version": "1.0.1",
  "license": "MIT",
  "icon": "resources/icon.png",
  "keywords": [
    "flag",
    "bookmark",
    "code marker",
    "highlight",
    "todo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sarangKaliyath/CodeFlag.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeflag.flag",
    "onCommand:codeflag.unflag"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeflag.welcomeMessage",
        "title": "welcome message",
        "category": "CodeFlag"
      },
      {
        "command": "codeflag.flag",
        "title": "Flag code",
        "category": "CodeFlag"
      },
      {
        "command": "codeflag.unflag",
        "title": "Unflag code",
        "category": "CodeFlag"
      },
      {
        "command": "codeflag.revealLine",
        "title": "Reveal Flag Location",
        "category": "CodeFlag"
      },
      {
        "command": "codeflag.removeFlagFromView",
        "title": "Remove",
        "category": "CodeFlag"
      },
      {
        "command": "codeflag.renameFlag",
        "title": "Rename",
        "category": "CodeFlag"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "codeflag.revealLine",
          "when": "false"
        },
        {
          "command": "codeflag.removeFlagFromView",
          "when": "false"
        },
        {
          "command": "codeflag.renameFlag",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "codeflag.flag",
          "when": "editorTextFocus",
          "group": "navigation"
        },
        {
          "command": "codeflag.unflag",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ],
      "editor/gutter/context": [
        {
          "command": "codeflag.flag",
          "when": "editorTextFocus",
          "group": "navigation"
        },
        {
          "command": "codeflag.unflag",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codeflag.removeFlagFromView",
          "when": "view == codeflagView && viewItem == flag",
          "group": "inline"
        },
        {
          "command": "codeflag.renameFlag",
          "when": "view == codeflagView && viewItem == flag",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeflagContainer",
          "title": "CodeFlag",
          "icon": "resources/flag.svg"
        }
      ]
    },
    "views": {
      "codeflagContainer": [
        {
          "id": "codeflagView",
          "name": "Code Flags"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codeflag.flag",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus"
      },
      {
        "command": "codeflag.unflag",
        "key": "ctrl+alt+u",
        "mac": "cmd+alt+u",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
