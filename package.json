{
  "name": "codeflag",
  "displayName": "CodeFlag",
  "description": "Allows you to add flags to your code, so that its easier to find later on...",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeflag.flag",
    "onCommand:codeflag.unflag"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeflag.welcomeMessage",
        "title": "welcome message"
      },
      {
        "command": "codeflag.flag",
        "title": "Flag code"
      },
      {
        "command": "codeflag.unflag",
        "title": "Unflag code"
      },
      {
        "command": "codeflag.revealLine",
        "title": "Reveal Flag Location"
      },
      {
        "command": "codeflag.removeFlagFromView",
        "title": "Remove"
      },
      {
        "command": "codeflag.renameFlag",
        "title": "Rename"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codeflag.flag",
          "when": "editorTextFocus",
          "group": "navigation"
        },
        {
          "command": "codeflag.unflag",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ],
      "editor/gutter/context": [
        {
          "command": "codeflag.flag",
          "when": "editorTextFocus",
          "group": "navigation"
        },
        {
          "command": "codeflag.unflag",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codeflag.removeFlagFromView",
          "when": "view == codeflagView && viewItem == flag",
          "group": "inline"
        },
        {
  "command": "codeflag.renameFlag",
  "when": "view == codeflagView && viewItem == flag",
  "group": "inline"
}
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeflagContainer",
          "title": "CodeFlag",
          "icon": "resources/flag.svg"
        }
      ]
    },
    "views": {
      "codeflagContainer": [
        {
          "id": "codeflagView",
          "name": "Code Flags"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
